# Database
DB_NAME=pagos_db
DB_USER=pagos_user
DB_PASS=password_muy_seguro_aqui

# Auth - CAMBIÁ esto por una clave larga y aleatoria
JWT_SECRET=genera_una_clave_larga_y_segura_aqui

# Seed (usuario inicial - solo se crea la primera vez)
SEED_EMAIL=tu@email.com
SEED_PASSWORD=password_seguro
SEED_NAME=Tu nombre

# Puerto donde Nginx escucha (default: 80)
NGINX_PORT=80
